# Ejemplo de .env. El instalador genera el .env real automáticamente.
# Copia este archivo a .env y ajusta los valores si quieres hacerlo a mano:
#   cp .env.example .env

# Puerto del host donde se publica el sitio (1-65535).
# Tu reverse-proxy/dominio debería apuntar a este puerto.
HOST_PORT=8384

# Nombre del proyecto compose (afecta a los nombres de red/contenedor).
COMPOSE_PROJECT_NAME=cafanet
